{
  "name": "cocos-playable-packer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "scan": "tsx src/scan.ts",
    "analyze": "tsx src/analyze-compression.ts",
    "analyze-entry": "tsx src/analyze-entry.ts",
    "analyze-modules": "tsx src/analyze-modules.ts",
    "analyze:solid": "tsx src/analyze-solid-compression.ts",
    "pack:raw": "tsx src/pack-uncompressed.ts",
    "pack:br": "tsx src/pack-compressed-cli.ts",
    "playable:build": "tsx src/pipeline/build-playable-image-quality-cli.ts",
    "web:mvp": "tsx src/web/web-mvp-server.ts",
    "serve": "http-server ./dist -p 8080 -c-1",
    "analyze:encoding": "tsx src/analyze-text-encoding.ts",
    "encoding:base91": "tsx src/encoding/reencode-brotli-html.ts",
    "encoding:html7": "tsx src/encoding/reencode-brotli-html7.ts",
    "typecheck": "tsc --noEmit",
    "test:build-service": "tsx src/service/build-playable-service-self-test.ts",
    "test:web-mvp": "tsx src/channel/channel-profile-self-test.ts && tsx src/channel/channel-mraid-adapter-self-test.ts && tsx src/web/web-mvp-self-test.ts && tsx src/web/web-config-panel-self-test.ts && tsx src/web/raw-single-html-self-test.ts",
    "analyze:resources": "tsx src/analyze-resource-optimization.ts",
    "audio:analyze": "tsx src/audio/analyze-build-audio.ts",
    "test:audio-analysis": "tsx src/audio/analyze-build-audio-self-test.ts",
    "audio:benchmark": "tsx src/audio/benchmark-build-audio.ts",
    "test:audio-benchmark": "tsx src/audio/benchmark-build-audio-self-test.ts",
    "audio:optimize": "tsx src/audio/optimize-build-audio.ts",
    "test:audio-optimize": "tsx src/audio/optimize-build-audio-self-test.ts",
    "webp:benchmark-build": "tsx src/webp/benchmark-build-webp.ts",
    "test:webp-benchmark": "tsx src/webp/benchmark-build-webp-self-test.ts && tsx src/images/image-content-type-self-test.ts",
    "webp:optimize-build": "tsx src/webp/optimize-build-webp.ts",
    "test:webp-optimize": "tsx src/webp/optimize-build-webp-self-test.ts",
    "tinypng:build": "node --env-file=.env --import tsx src/tinypng-build/compress-build-images.ts",
    "squoosh:test-one": "tsx src/squoosh/test-one.ts",
    "squoosh:benchmark-png": "tsx src/squoosh/benchmark-png-quantization.ts",
    "squoosh:benchmark-build-pngs": "tsx src/squoosh/benchmark-build-pngs.ts",
    "squoosh:apply-build-pngs": "tsx src/squoosh/apply-build-png-cache.ts",
    "squoosh:benchmark-build-jpegs": "tsx src/squoosh/optimize-build-jpegs.ts",
    "squoosh:apply-build-jpegs": "tsx src/squoosh/apply-build-jpeg-cache.ts",
    "squoosh:optimize-build-jpegs": "tsx src/squoosh/optimize-build-jpegs-cli.ts",
    "test:squoosh-jpeg": "tsx src/squoosh/optimize-build-jpegs-self-test.ts && tsx src/squoosh/apply-build-jpeg-cache-self-test.ts",
    "test:image-quality-pipeline": "tsx src/pipeline/build-playable-image-quality-self-test.ts",
    "images:optimize": "tsx src/images/optimize-build-images-cli.ts",
    "brotli:fallback:optimize": "tsx src/compression/optimize-brotli-fallback.ts",
    "test:brotli-fallback": "tsx src/compression/optimize-brotli-fallback-self-test.ts",
    "test:brotli-fallback-pipeline": "tsx src/pipeline/build-playable-brotli-fallback-self-test.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "brotli-compress": "^1.3.3",
    "http-server": "^14.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/oxipng": "^2.3.0",
    "@jsquash/webp": "^1.5.0",
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "cheerio": "^1.2.0",
    "music-metadata": "^11.13.0",
    "sharp": "^0.35.3",
    "tinify": "^1.8.3"
  }
}
